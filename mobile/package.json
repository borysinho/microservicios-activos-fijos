{
  "name": "MovilActivosFijos",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "android": "npm run android:debug:lan",
    "android:debug": "npm run android:debug:lan",
    "android:debug:lan": "ENVFILE=.env.development react-native run-android --mode debug --port 8088 --no-packager --active-arch-only --verbose",
    "android:debug:prod": "ENVFILE=.env.production react-native run-android --mode debug --port 8088 --no-packager --active-arch-only --verbose",
    "android:debug:reverse": "npm run android:reverse && ENVFILE=.env.reverse react-native run-android --mode debug --port 8088 --no-packager --active-arch-only --verbose",
    "android:release": "npm run android:release:prod",
    "android:release:prod": "ENVFILE=.env.production react-native run-android --mode release --port 8088 --no-packager --verbose",
    "android:build:release": "cd android && ENVFILE=.env.production ./gradlew assembleRelease",
    "android:full": "ENVFILE=.env.development react-native run-android --mode debug --port 8088 --verbose",
    "android:reverse": "adb reverse tcp:8088 tcp:8088 && adb reverse tcp:8081 tcp:8081 && adb reverse tcp:8002 tcp:8002 && adb reverse tcp:3000 tcp:3000",
    "ios": "npm run ios:debug:lan",
    "ios:debug:lan": "ENVFILE=.env.development react-native run-ios --port 8088",
    "ios:debug:prod": "ENVFILE=.env.production react-native run-ios --port 8088",
    "ios:release:prod": "ENVFILE=.env.production react-native run-ios --mode Release --port 8088",
    "start": "npm run start:debug",
    "start:debug": "ENVFILE=.env.development react-native start --port 8088",
    "start:prod": "ENVFILE=.env.production react-native start --port 8088",
    "test": "jest",
    "lint": "eslint .",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-native": "0.75.4",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "react-native-screens": "^3.34.0",
    "react-native-safe-area-context": "^4.11.0",
    "react-native-vision-camera": "^4.5.3",
    "react-native-geolocation-service": "^5.3.1",
    "@react-native-async-storage/async-storage": "^1.24.0",
    "@react-native-community/netinfo": "^11.4.1",
    "axios": "^1.7.7",
    "react-native-config": "^1.5.3",
    "react-native-maps": "1.18.0",
    "react-native-vector-icons": "^10.2.0",
    "@react-native-firebase/app": "^21.0.0",
    "@react-native-firebase/messaging": "^21.0.0"
  },
  "overrides": {
    "fast-xml-parser": "^5.7.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "@babel/runtime": "^7.25.0",
    "@react-native/babel-preset": "0.75.4",
    "@react-native/eslint-config": "0.75.4",
    "@react-native/metro-config": "0.75.4",
    "@react-native/typescript-config": "0.75.4",
    "@types/react": "^18.3.0",
    "@types/react-native": "^0.73.0",
    "@types/react-native-vector-icons": "^6.4.18",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "typescript": "5.0.4"
  },
  "jest": {
    "preset": "react-native"
  }
}
