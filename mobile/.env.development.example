# Debug en dispositivo fisico o emulador usando la IP LAN del servidor
# donde corren MS1, MS2 y MS3.
#
# Cambia MOBILE_DEV_SERVER_IP por la IP LAN de tu equipo/servidor.
# Ejemplo: 192.168.1.50, 10.0.0.25, 10.109.210.250.

MS1_BASE_URL=http://10.109.210.250:8081
MS2_BASE_URL=http://10.109.210.250:8002/api
MS3_BASE_URL=http://10.109.210.250:3000/api
