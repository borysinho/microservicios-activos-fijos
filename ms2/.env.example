# AWS Credentials — usar credenciales reales en producción
# Para desarrollo local con LocalStack, usar los valores fake de abajo
MS2_AWS_ACCESS_KEY_ID=test
MS2_AWS_SECRET_ACCESS_KEY=test
# AWS Academy / STS temporal: pegar tambien el token de sesion.
# MS2_AWS_SESSION_TOKEN=
MS2_AWS_REGION=us-east-1

# LocalStack — descomentar para desarrollo local, dejar vacío para AWS real
MS2_AWS_ENDPOINT_URL=http://localhost:4566

# Puerto del servidor (uvicorn)
# El servidor corre en el puerto 8002

# S3
MS2_S3_BUCKET_NAME=activos-fijos-documentos-dev

# DynamoDB
MS2_DYNAMODB_TABLE_DOCS=activos-fijos-ms2-documentos
MS2_DYNAMODB_TABLE_AUDITORIA=activos-fijos-ms2-auditoria

# En LocalStack/desarrollo puede crear recursos al arrancar.
# En Lambda produccion CloudFormation crea los recursos y este valor va en false.
MS2_AUTO_BOOTSTRAP_AWS_RESOURCES=true

# JWT (debe coincidir con el secret de MS1)
MS2_JWT_SECRET=saf-ms1-super-secret-key-2026-activos-fijos-bolivia-uagrm
MS2_JWT_ALGORITHM=HS512

# CORS
MS2_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:8100

# Desarrollo — cargar modelos IA desde filesystem local en vez de S3
# 1. Ejecutar primero: python scripts/train_models.py
# 2. Descomentar la línea siguiente:
# MS2_LOCAL_MODELS_PATH=/tmp
MS2_LOAD_AI_MODELS=true
